# Whitelist .gitignore — exclude EVERYTHING by default, then explicitly re-include
# only code + non-PII operational docs. Belt-and-suspenders against PII leakage.

# 1) Block everything
*

# 2) Re-include code + non-PII docs
!.gitignore
!README.md
!MIGRATION.md
!scripts/
!scripts/**
!crm/
!crm/**
!.full-stack-feature/
!.full-stack-feature/**

# 3) Even within whitelisted dirs, never include local state / secrets / build output
scripts/_*.txt
scripts/_*.json
scripts/__pycache__/
scripts/*.pyc

crm/node_modules/
crm/.next/
crm/.env
crm/.env.local
crm/.env.*.local
crm/coverage/
crm/test-results/
crm/playwright-report/
crm/playwright/.cache/
crm/.turbo/

.full-stack-feature/state.json

# 4) Hard blocks that MUST stay excluded regardless of any future re-include attempt
.env
.env.*
_sales_os_state.json
*.xlsx
*.xls
*.xlsm
*.csv
*.tsv
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
verification_V*.json
_weekly_xlsx_b64.txt
*.~lock.*#
.~lock.*
.DS_Store
.claude/
_archive/
apify_data/
enrichment/
MASTER/uploads_to_drive/
